meta {
  name: Create Organization
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/organizations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Test Organization",
    "slug": "test-org",
    "plan": "free",
    "ownerEmail": "owner@example.com"
  }
}
